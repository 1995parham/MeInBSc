---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Me In BSc.',
  description = 'یادگاری‌ها و خاطرات دوستان پرهام الوانی از دوران کارشناسی در دانشکده مهندسی کامپیوتر دانشگاه صنعتی امیرکبیر.',
  image = 'assets/img/logo.png',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(asset(image), Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: title,
  url: canonical.href,
  inLanguage: 'fa-IR',
  description,
  author: {
    '@type': 'Person',
    name: 'Parham Alvani',
  },
};
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#059669" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b3d2e" media="(prefers-color-scheme: dark)" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Parham Alvani" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" type="image/png" href={asset('assets/img/logo.png')} />
    <link rel="sitemap" href={asset('sitemap-index.xml')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Me In BSc." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:locale" content="fa_IR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.href} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />

    <link rel="preconnect" href="https://1995parham.me" />
    <link rel="stylesheet" href={asset('assets/css/app.css')} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>
        <img class="logo" src={asset('assets/img/logo.png')} alt="Me In BSc." width="54" height="54" />
        <h1>یادگاری‌های دوران کارشناسی</h1>
      </a>
      <p class="subtitle">
        خاطراتی که دوستانم در جشن فارغ‌التحصیلی دانشکده مهندسی کامپیوتر دانشگاه
        صنعتی امیرکبیر برایم نوشتند.
      </p>
    </header>

    <main class="memories">
      <slot />
    </main>

    <footer class="site-footer">
      <p>ساخته‌شده با ❤ — پرهام الوانی</p>
    </footer>
  </body>
</html>
