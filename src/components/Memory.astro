---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  memory: CollectionEntry<'memories'>;
}

const { memory } = Astro.props;
const { title, author, image, video, poster, videoLink } = memory.data;
const { Content } = await render(memory);

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

// A self-hosted file (relative path) gets a native <video>; a URL gets an iframe.
const isLocalVideo = video ? !/^https?:\/\//.test(video) : false;
---

<article class="memory">
  <header class="memory__header">
    <h2 class="memory__title">{title}</h2>
    <p class="memory__author">{author}</p>
  </header>
  <div class="memory__body">
    <Content />
    {image && <img class="memory__media" src={asset(`assets/img/${image}`)} alt={`عکس ${title}`} loading="lazy" />}
    {
      video && isLocalVideo && (
        <video
          class="memory__player"
          controls
          playsinline
          preload="metadata"
          poster={poster ? asset(poster) : undefined}
        >
          <source src={asset(video)} type="video/mp4" />
        </video>
      )
    }
    {
      video && !isLocalVideo && (
        <div class="memory__video">
          <iframe
            src={video}
            title={title}
            loading="lazy"
            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      )
    }
    {
      videoLink && (
        <p class="memory__video-link">
          <a href={videoLink} target="_blank" rel="noopener">تماشا در یوتیوب ↗</a>
        </p>
      )
    }
  </div>
</article>
