---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  memory: CollectionEntry<'memories'>;
}

const { memory } = Astro.props;
const { title, author, image, video } = memory.data;
const { Content } = await render(memory);

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---

<div class="row">
  <div class="col-md-8 offset-md-2 col-sm-12">
    <div class="card text-right">
      <div class="card-header card-header-success">
        <h4 class="card-title" style="direction: rtl;">{title}</h4>
        <p class="category" style="direction: rtl;">{author}</p>
      </div>
      <div class="card-body">
        <Content />
        {image && <img src={asset(`assets/img/${image}`)} alt={`img-${image}`} style="width: 100%" />}
        {
          video && (
            <iframe
              height="315"
              src={video}
              frameborder="0"
              style="width: 100%"
              allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          )
        }
      </div>
    </div>
  </div>
</div>
