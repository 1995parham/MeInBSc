---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  memory: CollectionEntry<'memories'>;
}

const { memory } = Astro.props;
const { title, author, image, video } = memory.data;
const { Content } = await render(memory);

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
---

<article class="memory">
  <header class="memory__header">
    <h2 class="memory__title">{title}</h2>
    <p class="memory__author">{author}</p>
  </header>
  <div class="memory__body">
    <Content />
    {image && <img class="memory__media" src={asset(`assets/img/${image}`)} alt={`عکس ${title}`} loading="lazy" />}
    {
      video && (
        <div class="memory__video">
          <iframe
            src={video}
            title={title}
            loading="lazy"
            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      )
    }
  </div>
</article>
